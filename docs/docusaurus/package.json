{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "@eslint-plugin-copilot/docs",
    "version": "0.1.0",
    "private": true,
    "description": "Docusaurus documentation site for eslint-plugin-copilot.",
    "keywords": [
        "copilot",
        "documentation",
        "docusaurus",
        "eslint",
        "eslint-plugin",
        "github-copilot"
    ],
    "homepage": "https://nick2bad4u.github.io/eslint-plugin-copilot/",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/eslint-plugin-copilot/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/eslint-plugin-copilot.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "sideEffects": false,
    "main": "docusaurus.config.ts",
    "files": [
        "build"
    ],
    "scripts": {
        "build": "docusaurus build",
        "build:fast": "cross-env DOCUSAURUS_ENABLE_EXPERIMENTAL=true docusaurus build",
        "build:local": "docusaurus build",
        "clear": "docusaurus clear",
        "deploy": "docusaurus deploy",
        "docs:api": "node -e \"console.log('No generated API docs configured for eslint-plugin-copilot.')\"",
        "docs:api:local": "node -e \"console.log('No generated API docs configured for eslint-plugin-copilot.')\"",
        "docusaurus": "docusaurus",
        "serve": "docusaurus serve",
        "start": "docusaurus start --host localhost",
        "start:devtools": "cross-env DOCUSAURUS_BASE_URL=/ docusaurus start --host localhost",
        "type:css": "npx typed-css-modules .\\src",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "write-heading-ids": "docusaurus write-heading-ids",
        "write-translations": "docusaurus write-translations"
    },
    "dependencies": {
        "@docusaurus/core": "^3.9.2",
        "@docusaurus/faster": "^3.9.2",
        "@docusaurus/plugin-content-docs": "^3.9.2",
        "@docusaurus/preset-classic": "^3.9.2",
        "@docusaurus/types": "^3.9.2",
        "clsx": "^2.1.1",
        "prism-react-renderer": "^2.4.1"
    },
    "devDependencies": {
        "@docusaurus/module-type-aliases": "^3.9.2",
        "@docusaurus/tsconfig": "^3.9.2",
        "@mdx-js/react": "^3.1.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typed-css-modules": "^0.9.1",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "packageManager": "npm@11.12.0",
    "engines": {
        "node": ">=22.0.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=22.0.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": ">=11.0.0",
            "onFail": "error"
        }
    }
}
